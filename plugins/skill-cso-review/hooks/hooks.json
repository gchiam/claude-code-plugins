{
  "description": "Post-edit CSO compliance check for SKILL.md files",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-skill-cso.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
